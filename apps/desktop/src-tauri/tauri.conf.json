{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YT Downloader Desktop",
  "version": "0.1.0",
  "identifier": "com.studiobox101.ytdownloader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "YT Downloader Desktop",
        "width": 980,
        "height": 760,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
