{
  "name": "yt-downloader-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "nx run-many --projects=backend,frontend --target=dev --parallel",
    "build": "nx run-many --projects=backend,frontend --target=build",
    "serve:backend": "nx run backend:serve",
    "serve:frontend": "nx run frontend:serve",
    "dev:desktop": "nx run-many --projects=backend,desktop --target=dev --parallel",
    "dev:desktop:app": "nx run desktop:dev",
    "serve:desktop": "nx run desktop:serve",
    "build:desktop": "nx run desktop:build"
  },
  "devDependencies": {
    "nx": "^20.8.2"
  }
}
